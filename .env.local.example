GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override model (default: gemini-1.5-flash). Try gemini-1.5-pro, gemini-2.5-flash, etc.
# GEMINI_MODEL=gemini-1.5-flash

# PostgreSQL (for saving analyses and share links)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paper_translator?schema=public"

# Auth0 (optional - app works for guests without these)
# Generate AUTH0_SECRET with: openssl rand -hex 32
AUTH0_SECRET=
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3000
